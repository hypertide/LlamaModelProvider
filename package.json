{
  "name": "llamamodelprovider",
  "displayName": "LlamaModelProvider",
  "description": "Llama.CPP Model Provider",
  "version": "0.0.2",
  "publisher": "Hypertide",
  "repository": {
    "url": "https://www.github.com/hypertide/LlamaModelProvider"
  },
  "author": {
    "name": "Hypertide"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Machine Learning"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "llamacpp-model-provider",
        "displayName": "Llama.CPP Model Provider"
      }
    ]
      ,
      "configuration": [
        {
          "type": "object",
          "title": "Llama CPP Model Provider Settings",
          "properties": {
            "llmcppprov.models": {
              "type": "object",
              "description": "Models definitions.",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "url": { "type": "string" },
                    "family": { "type": "string" },
                    "version": { "type": "string" },
                    "maxInputTokens": { "type": "integer" },
                    "maxOutputTokens": { "type": "integer" },
                    "capabilities": {
                      "type": "object",
                      "properties": {
                        "toolCalling": { "type": "boolean" }
                      },
                      "required": ["toolCalling"]
                    }
                  },
                  "required": [
                    "id",
                    "url",
                    "maxInputTokens",
                    "maxOutputTokens",
                    "capabilities"
                  ]
                }
            }
          }
        }
      ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
